<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="studio.ide.ui.EditorView"
      style="-fx-background-color: #1e1e1e;">

    <HBox VBox.vgrow="ALWAYS" style="-fx-background-color: #1e1e1e;">
        <!-- Column for Line Numbers -->
        <TextArea fx:id="lineNumbersArea"
                  prefWidth="40"
                  editable="false"
                  focusTraversable="false"
                  style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: #858585; -fx-font-family: 'Consolas', monospace; -fx-font-size: 16px; -fx-background-color: transparent; -fx-border-width: 0; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-padding: 0;"/>
        <!-- Main Assembly Code Area -->
        <TextArea fx:id="mainCodeEditor"
                  HBox.hgrow="ALWAYS"
                  style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: #d4d4d4; -fx-font-family: 'Consolas', monospace; -fx-font-size: 16px; -fx-focus-color: transparent; -fx-faint-focus-color: transparent; -fx-padding: 0;"/>
    </HBox>
</VBox>