<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="studio.ide.ui.MainController"
            style="-fx-background-color: #1e1e1e;">

    <top>
        <HBox spacing="10" style="-fx-background-color: #333333; -fx-padding: 10;">
            <Button fx:id="executeBtn" text="Run Code (F5)" style="-fx-background-color: #0e639c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="stepBtn" text="Step (F10)" style="-fx-background-color: #4d4d4d; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <fx:include source="editor.fxml" fx:id="editor" />
    </center>

    <right>
        <fx:include source="memory_table.fxml" fx:id="memoryTable" />
    </right>

</BorderPane>