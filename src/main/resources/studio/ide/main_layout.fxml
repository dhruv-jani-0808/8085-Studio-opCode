<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.MenuItem?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="studio.ide.ui.MainController"
            style="-fx-background-color: #1e1e1e;">

    <top>
        <HBox spacing="15" style="-fx-background-color: #2d2d2d; -fx-padding: 5 15 5 15; -fx-border-color: #333333; -fx-border-width: 0 0 1 0; -fx-alignment: CENTER_LEFT;">
            <!-- File Button with nested ContextMenu for hover behavior -->
            <Button fx:id="fileButton" text="File" style="-fx-background-color: #4d4d4d; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;">
                <contextMenu>
                    <ContextMenu fx:id="fileContextMenu">
                        <items>
                            <MenuItem fx:id="newFileMenuItem" text="New File          Ctrl+N" style="-fx-font-size: 13px;"/>
                            <MenuItem fx:id="openFileMenuItem" text="Open File         Ctrl+O" style="-fx-font-size: 13px;"/>
                            <MenuItem fx:id="saveMenuItem" text="Save              Ctrl+S" style="-fx-font-size: 13px;"/>
                            <MenuItem fx:id="saveAsMenuItem" text="Save As..." style="-fx-font-size: 13px;"/>
                        </items>
                    </ContextMenu>
                </contextMenu>
            </Button>
            
            <Pane HBox.hgrow="NEVER" prefWidth="15"/>
            
            <Button fx:id="executeBtn" text="Run Code (F5)" style="-fx-background-color: #0e639c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand;"/>
            <Button fx:id="stepBtn" text="Step (F10)" style="-fx-background-color: #4d4d4d; -fx-text-fill: white; -fx-font-size: 14px; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <center>
        <fx:include source="editor.fxml" fx:id="editor" />
    </center>

    <right>
        <fx:include source="memory_table.fxml" fx:id="memoryTable" />
    </right>

</BorderPane>