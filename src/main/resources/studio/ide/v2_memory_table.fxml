<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TextField?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="studio.ide.ui.MemoryTableView"
      prefWidth="310"
      minWidth="260"
      style="-fx-background-color: #252526;
             -fx-border-color: #1e1e1e;
             -fx-border-width: 0 0 0 1;">

    <!-- ── Panel Header ── -->
    <HBox style="-fx-background-color: #252526;
                 -fx-padding: 7 12 7 12;
                 -fx-border-color: #3e3e3e;
                 -fx-border-width: 0 0 1 0;
                 -fx-min-height: 30;
                 -fx-alignment: CENTER_LEFT;">
        <Label text="MEMORY"
               style="-fx-text-fill: #d4d4d4;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-letter-spacing: 2;"/>
    </HBox>

    <!-- ── Search bar ── -->
    <HBox spacing="6"
          style="-fx-padding: 8 8 6 8;
                 -fx-alignment: CENTER_LEFT;
                 -fx-background-color: #252526;">
        <TextField fx:id="searchField"
                   promptText="Jump to address  (e.g. 2000H)"
                   HBox.hgrow="ALWAYS"
                   onAction="#handleAddressSearch"
                   style="-fx-background-color: #3c3c3c;
                          -fx-text-fill: #d4d4d4;
                          -fx-font-size: 13px;
                          -fx-prompt-text-fill: #6e6e6e;
                          -fx-border-color: #555555;
                          -fx-border-width: 1;
                          -fx-background-radius: 3;
                          -fx-border-radius: 3;
                          -fx-padding: 5 8 5 8;"/>
        <Button text="Go"
                onAction="#handleAddressSearch"
                focusTraversable="false"
                style="-fx-background-color: #0e639c;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-cursor: hand;
                       -fx-background-radius: 3;
                       -fx-padding: 5 14 5 14;"/>
    </HBox>

    <Separator style="-fx-background-color: #3e3e3e;"/>

    <!-- ── Memory grid ── -->
    <TableView fx:id="memoryTable" VBox.vgrow="ALWAYS"
               style="-fx-base: #1e1e1e;
                      -fx-control-inner-background: #1e1e1e;
                      -fx-table-cell-border-color: #2d2d2d;
                      -fx-font-size: 13px;
                      -fx-font-family: 'Consolas', monospace;
                      -fx-selection-bar: #264f78;
                      -fx-selection-bar-text: #d4d4d4;
                      -fx-focus-color: transparent;
                      -fx-faint-focus-color: transparent;">
        <columns>
            <TableColumn fx:id="hexAddrCol" text="Address" prefWidth="95"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="decAddrCol" text="Decimal" prefWidth="85"
                         style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="dataCol"    text="Data"    prefWidth="100"
                         style="-fx-alignment: CENTER;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
